config {
  type: "incremental",
  schema: "retail_gold",
  name: "sales_gold_audit"
}

SELECT
  COUNT(*) AS total_aggregated_rows,

  MIN(sale_date) AS start_date,
  MAX(sale_date) AS end_date,

  CASE 
    WHEN COUNT(*) > 0 THEN 'SUCCESS'
    ELSE 'FAILURE'
  END AS status,

  CURRENT_TIMESTAMP() AS processing_timestamp

FROM ${ref("sales_gold")}